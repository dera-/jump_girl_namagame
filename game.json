{
	"width": 1280,
	"height": 720,
	"fps": 30,
	"main": "./script/_bootstrap.js",
	"assets": {
		"se": {
			"type": "audio",
			"path": "audio/se",
			"systemId": "sound",
			"duration": 250,
			"hint": {
				"extensions": [
					".aac",
					".ogg"
				]
			}
		},
		"_bootstrap": {
			"type": "script",
			"path": "script/_bootstrap.js",
			"global": true
		},
		"main": {
			"type": "script",
			"path": "script/main.js",
			"global": true
		},
		"item_drink1": {
			"type": "image",
			"path": "image/item_drink1.png",
			"width": 1024,
			"height": 1536
		},
		"item_drink2": {
			"type": "image",
			"path": "image/item_drink2.png",
			"width": 1024,
			"height": 1536
		},
		"jump_girl": {
			"type": "image",
			"path": "image/jump_girl.png",
			"width": 1536,
			"height": 1024
		},
		"arrow": {
			"type": "image",
			"path": "image/arrow.png",
			"width": 1536,
			"height": 1024
		},
		"background": {
			"type": "image",
			"path": "image/background.png",
			"width": 1536,
			"height": 1024
		},
		"block": {
			"type": "image",
			"path": "image/block.png",
			"width": 27,
			"height": 24
		},
		"dialog": {
			"type": "image",
			"path": "image/dialog.png",
			"width": 1613,
			"height": 467
		},
		"girl_face": {
			"type": "image",
			"path": "image/girl_face.png",
			"width": 1303,
			"height": 1206
		}
	},
	"environment": {
		"sandbox-runtime": "3",
		"nicolive": {
			"supportedModes": [
				"ranking"
			],
			"preferredSessionParameters": {
				"totalTimeLimit": 95
			}
		}
	},
	"globalScripts": [
		"node_modules/@akashic-extension/akashic-box2d/lib/Box2D.js",
		"node_modules/@akashic-extension/akashic-box2d/lib/ContactManager.js",
		"node_modules/@akashic-extension/akashic-box2d/lib/index.js",
		"node_modules/@akashic-extension/akashic-box2d/lib/parameters.js",
		"node_modules/box2dweb/box2d.js"
	],
	"moduleMainScripts": {
		"@akashic-extension/akashic-box2d": "node_modules/@akashic-extension/akashic-box2d/lib/index.js",
		"box2dweb": "node_modules/box2dweb/box2d.js"
	}
}